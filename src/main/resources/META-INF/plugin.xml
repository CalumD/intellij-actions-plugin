<idea-plugin>
    <id>com.clumd.projects.intellijactionsplugin</id>
    <name>Ide Streamdeck Integration</name>
    <description>
        <![CDATA[
            <html>
              <p>Adds support for the Elgato StreamDeck to call into IntelliJ
              from anywhere on the running system and execute actions.</p>
            </html>
        ]]>
    </description>
    <vendor url="https://github.com/CalumD/intellij-actions-plugin">CalumD</vendor>

    <version>0.0.1</version>
    <idea-version since-build="173.0"/>

    <change-notes>
        <![CDATA[
            <html>
              <b>0.0.1</b> (2021-08-24)
              <ul>
                <li> Still in development, report any issues on the linked Github issues. </li>
              </ul>
            </html>
        ]]>
    </change-notes>

    <!-- Product and plugin compatibility requirements -->
    <!-- https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Add your extensions here -->
        <backgroundPostStartupActivity implementation="com.clumd.projects.intellijactionsplugin.StreamDeckInputServer" order="last"/>
    </extensions>
</idea-plugin>
